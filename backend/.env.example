PORT=8787
NODE_ENV=development
DATABASE_URL="mysql://root:password@localhost:3306/posyandu_kms"
PRISMA_CLIENT_ENGINE_TYPE="library"
# Alternatif jika hosting meminta variable DB terpisah:
# DB_HOST="localhost"
# DB_PORT="3306"
# DB_USER="root"
# DB_PASSWORD="password"
# DB_NAME="posyandu_kms"
JWT_ACCESS_SECRET="change-this-access-secret"
JWT_REFRESH_SECRET="change-this-refresh-secret"
JWT_ACCESS_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="360d"
APP_PUBLIC_BASE_URL="http://localhost:8787"
CORS_ORIGIN="http://localhost:8787,http://127.0.0.1:8787,http://localhost:5173,http://127.0.0.1:5173"
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@posyandu.local"
REDIRECT_FROM_PORT=0
